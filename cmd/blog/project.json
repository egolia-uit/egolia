{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "blog",
  "projectType": "application",
  "tags": ["scope:service", "type:go"],
  "namedInputs": {
    "default": [
      "goPkgFiles",
      "goFiles",
      "{workspaceRoot}/api/**/*.go",
      "{workspaceRoot}/internal/blog/**/*.go"
    ]
  },
  "targets": {
    "gen:wire": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "outputs": ["{projectRoot}/wire_gen.go"],
      "options": {
        "command": "wire",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "dev": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "go run .",
        "cwd": "{projectRoot}",
        "tty": true
      },
      "dependsOn": ["gen:wire", "^gen*"],
      "continuous": true
    },
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "go build -o ./blog .",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["gen:wire", "^gen*", "^build*"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "./blog",
        "cwd": "{projectRoot}",
        "tty": true
      },
      "continuous": true,
      "dependsOn": ["build"]
    },
    "debug": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "dlv debug --headless --listen=127.0.0.1:23453 --accept-multiclient",
        "cwd": "{projectRoot}",
        "tty": true
      },
      "dependsOn": ["gen:wire", "^gen*"],
      "continuous": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run ./...",
        "cwd": "{projectRoot}"
      },
      "cache": false,
      "parallelism": false
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod tidy"
      }
    },
    "nx-release-publish": {
      "parallelism": false
    }
  },
  "implicitDependencies": ["pkg"],
  "release": {
    "docker": {
      "repositoryName": "egolia-uit/blog"
    }
  }
}
