{
  "openapi": "3.0.4",
  "info": {
    "description": "Egolia API",
    "version": "0.0.0",
    "title": "Egolia API",
    "license": {
      "name": "MIT",
      "url": "https://github.com/egolia-uit/egolia/blob/main/LICENSE"
    },
    "contact": {
      "name": "Egolia Support",
      "email": "egolia@googlegroups.com"
    }
  },
  "servers": [
    {
      "url": "http://api.egolia.localhost"
    }
  ],
  "tags": [
    {
      "name": "Course",
      "description": "Course",
      "x-displayName": "Course"
    },
    {
      "name": "Section",
      "description": "Section",
      "x-displayName": "Section"
    },
    {
      "name": "Lesson",
      "description": "Lesson",
      "x-displayName": "Lesson"
    },
    {
      "name": "Test",
      "description": "Test",
      "x-displayName": "Test"
    }
  ],
  "externalDocs": {
    "url": "https://egolia-uit.github.io/egolia"
  },
  "paths": {
    "/course/courses": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Course"
        ],
        "summary": "Create course",
        "operationId": "createCourse",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Course"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Course created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/courses/{courseId}": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Course"
        ],
        "summary": "Get course",
        "operationId": "getCourse",
        "parameters": [
          {
            "$ref": "#/components/parameters/courseIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "patch": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Course"
        ],
        "summary": "Change basic course info",
        "operationId": "changeBasicCourseInfo",
        "parameters": [
          {
            "$ref": "#/components/parameters/courseIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255,
                    "example": "OOP A-Z Updated"
                  },
                  "slug": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255,
                    "example": "oop-a-z-updated"
                  },
                  "status": {
                    "$ref": "#/components/schemas/status"
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "minimum": 0,
                    "example": 119.99
                  }
                },
                "minProperties": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Course basic information updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/sections": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Section"
        ],
        "summary": "Create section",
        "operationId": "createSection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "courseId",
                  "title"
                ],
                "properties": {
                  "courseId": {
                    "$ref": "#/components/schemas/properties-id"
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255,
                    "example": "OOP Fundamentals"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Section created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Section"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/sections/{sectionId}": {
      "delete": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Section"
        ],
        "summary": "Delete section",
        "operationId": "deleteSection",
        "parameters": [
          {
            "$ref": "#/components/parameters/sectionIdPath"
          }
        ],
        "responses": {
          "204": {
            "description": "Section successfully deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/lessons": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Lesson"
        ],
        "summary": "Create lesson",
        "operationId": "createLesson",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "courseId",
                  "sectionId",
                  "title"
                ],
                "properties": {
                  "courseId": {
                    "$ref": "#/components/schemas/properties-id"
                  },
                  "sectionId": {
                    "$ref": "#/components/schemas/Section_properties-id"
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255,
                    "example": "Encapsulation Overview"
                  },
                  "previousLessonId": {
                    "type": "string",
                    "format": "uuid",
                    "nullable": true,
                    "example": "ed405041-986f-4750-92e6-617dd9337a78"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lesson created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lesson"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/lessons/{lessonId}": {
      "patch": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Lesson"
        ],
        "summary": "Edit lesson",
        "operationId": "editLesson",
        "parameters": [
          {
            "$ref": "#/components/parameters/lessonIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255,
                    "example": "Encapsulation Deep Dive"
                  },
                  "previousLessonId": {
                    "type": "string",
                    "format": "uuid",
                    "nullable": true,
                    "example": "ed405041-986f-4750-92e6-617dd9337a78"
                  },
                  "videoUrl": {
                    "type": "string",
                    "format": "uri",
                    "example": "https://cdn.egolia.localhost/videos/lesson-1.mp4"
                  },
                  "duration": {
                    "type": "integer",
                    "format": "int64",
                    "minimum": 1,
                    "example": 300
                  }
                },
                "minProperties": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lesson updated",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/Lesson"
                    },
                    {
                      "$ref": "#/components/schemas/VideoLesson"
                    },
                    {
                      "$ref": "#/components/schemas/TestLesson"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Lesson"
        ],
        "summary": "Delete lesson",
        "operationId": "deleteLesson",
        "parameters": [
          {
            "$ref": "#/components/parameters/lessonIdPath"
          }
        ],
        "responses": {
          "204": {
            "description": "Lesson successfully deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/lessons/{lessonId}/upload-video-url": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Lesson"
        ],
        "summary": "Get upload video lesson URL",
        "operationId": "getUploadVideoLessonUrl",
        "parameters": [
          {
            "$ref": "#/components/parameters/lessonIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Upload URL generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "uploadUrl",
                    "objectKey",
                    "expiresAt"
                  ],
                  "properties": {
                    "uploadUrl": {
                      "type": "string",
                      "format": "uri",
                      "example": "https://storage.egolia.localhost/upload/signed-url-token"
                    },
                    "objectKey": {
                      "type": "string",
                      "example": "lessons/46f94d4d-41b5-4df6-bf8d-270fb9a49c97/video.mp4"
                    },
                    "expiresAt": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-03-22T10:30:00Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/lessons/{lessonId}/tests": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Test"
        ],
        "summary": "Create test",
        "operationId": "createTest",
        "parameters": [
          {
            "$ref": "#/components/parameters/lessonIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "questions"
                ],
                "properties": {
                  "type": {
                    "$ref": "#/components/schemas/TestLessonType"
                  },
                  "questions": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "$ref": "#/components/schemas/TestQuestion"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Test created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestLesson"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Oauth2": {
        "type": "oauth2",
        "description": "OAuth2 Security Scheme",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "http://authentik.egolia.localhost/application/o/authorize",
            "tokenUrl": "http://authentik.egolia.localhost/application/o/token",
            "scopes": {
              "openid": "Required for OIDC",
              "profile": "Access to user profile"
            },
            "x-defaultClientId": "api-web",
            "x-scalar-client-id": "api-web",
            "x-usePkce": "SHA-256",
            "x-scalar-credentials-location": "header"
          }
        }
      }
    },
    "schemas": {
      "id": {
        "type": "string",
        "format": "number",
        "description": "User ID from Authentik (need to change subject mode to User's ID instead of hashed)",
        "example": "100"
      },
      "Course": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "readOnly": true
          },
          "title": {
            "type": "string",
            "example": "Introduction to Programming"
          },
          "slug": {
            "type": "string",
            "example": "introduction-to-programming"
          },
          "instructorId": {
            "$ref": "#/components/schemas/id"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "approved",
              "published",
              "archived"
            ],
            "example": "draft"
          },
          "price": {
            "type": "integer",
            "format": "int64",
            "example": 1000000
          }
        },
        "required": [
          "id",
          "title",
          "slug",
          "instructorId",
          "status",
          "price"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code",
            "example": "EXAMPLE_CODE"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Example error"
          },
          "more_info": {
            "type": "string",
            "description": "URL with more information about the error",
            "example": "https://api.egolia.com/docs/errors/EXAMPLE_CODE"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "123e4567-e89b-12d3-a456-426614174000",
        "readOnly": true
      },
      "status": {
        "type": "string",
        "enum": [
          "draft",
          "approved",
          "published",
          "archived"
        ],
        "example": "draft"
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "0de4f8f2-3440-4e29-9b88-9cfbbf4476fc",
            "readOnly": true
          },
          "courseId": {
            "$ref": "#/components/schemas/properties-id"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "OOP Fundamentals"
          }
        },
        "required": [
          "id",
          "courseId",
          "title"
        ]
      },
      "Section_properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "0de4f8f2-3440-4e29-9b88-9cfbbf4476fc",
        "readOnly": true
      },
      "Lesson_properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "2926aa3f-29ad-449b-9556-c44d4fc676a0",
        "readOnly": true
      },
      "Lesson": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "2926aa3f-29ad-449b-9556-c44d4fc676a0",
            "readOnly": true
          },
          "courseId": {
            "$ref": "#/components/schemas/properties-id"
          },
          "title": {
            "type": "string",
            "example": "Introduction to Python"
          },
          "previousLessonId": {
            "$ref": "#/components/schemas/Lesson_properties-id",
            "example": "ed405041-986f-4750-92e6-617dd9337a78",
            "writeOnly": true
          }
        },
        "required": [
          "id",
          "title",
          "courseId"
        ]
      },
      "VideoLesson": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Lesson"
          },
          {
            "type": "object",
            "properties": {
              "videoUrl": {
                "type": "string",
                "format": "uri",
                "example": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
              },
              "duration": {
                "type": "integer",
                "format": "int64",
                "example": 300
              }
            },
            "required": [
              "videoUrl",
              "duration"
            ]
          }
        ]
      },
      "TestLesson": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Lesson"
          },
          {
            "type": "object",
            "required": [
              "type",
              "questions"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "singleChoice",
                  "multipleChoice"
                ],
                "example": "singleChoice"
              },
              "questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "x-go-type-name": "TestQuestion",
                  "required": [
                    "id",
                    "question",
                    "answers"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid",
                      "example": "6da7726c-18ba-4513-baa1-7e0eeef126d5",
                      "readOnly": true
                    },
                    "question": {
                      "type": "string",
                      "example": "What is the capital of France?"
                    },
                    "answers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "x-go-type-name": "TestAnswer",
                        "required": [
                          "id",
                          "content",
                          "isCorrect"
                        ],
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid",
                            "example": "bd0b3d9a-c5aa-497f-a904-a19cd1a5b3d6",
                            "readOnly": true
                          },
                          "content": {
                            "type": "string",
                            "example": "Paris"
                          },
                          "isCorrect": {
                            "type": "boolean",
                            "example": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "TestLessonType": {
        "type": "string",
        "enum": [
          "multipleChoice",
          "singleChoice"
        ],
        "example": "singleChoice"
      },
      "TestAnswer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "4c413364-151d-44e4-a357-c0c5cf7c5f4a",
            "readOnly": true
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "example": "Encapsulation hides implementation details behind a stable API."
          },
          "isCorrect": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "id",
          "content",
          "isCorrect"
        ]
      },
      "TestQuestion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "af2fb7f2-cf11-40d4-8628-b28f7d40f933",
            "readOnly": true
          },
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000,
            "example": "Which principle of OOP enables exposing only essential behavior?"
          },
          "answers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/TestAnswer"
            }
          }
        },
        "required": [
          "id",
          "question",
          "answers"
        ]
      }
    },
    "responses": {
      "BadRequestError": {
        "description": "Bad Request Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
