{
  "openapi": "3.0.4",
  "info": {
    "description": "Egolia API\n",
    "version": "0.0.0",
    "title": "Egolia API",
    "license": {
      "name": "MIT",
      "url": "https://github.com/egolia-uit/egolia/blob/main/LICENSE"
    },
    "contact": {
      "name": "Egolia Support",
      "email": "egolia@googlegroups.com"
    },
    "x-apiName": "course"
  },
  "servers": [
    {
      "url": "http://api.egolia.localhost"
    }
  ],
  "tags": [
    {
      "name": "Course",
      "description": "Course"
    },
    {
      "name": "Lesson",
      "description": "Lesson"
    }
  ],
  "externalDocs": {
    "url": "https://egolia-uit.github.io/egolia"
  },
  "paths": {
    "/course/courses": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Course"
        ],
        "summary": "Create course",
        "operationId": "createCourse",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Course"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Course created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/courses/{courseId}": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Course"
        ],
        "summary": "Get course",
        "operationId": "getCourse",
        "parameters": [
          {
            "$ref": "#/components/parameters/courseIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/course/lessons": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Lesson"
        ],
        "summary": "Create lesson",
        "operationId": "createLesson",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "video": {
                    "$ref": "#/components/schemas/VideoLesson"
                  },
                  "test": {
                    "$ref": "#/components/schemas/TestLesson"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lesson created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Lesson"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Oauth2": {
        "type": "oauth2",
        "description": "OAuth2 Security Scheme",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "http://authentik.egolia.localhost/application/o/authorize",
            "tokenUrl": "http://authentik.egolia.localhost/application/o/token",
            "scopes": {
              "openid": "Required for OIDC",
              "profile": "Access to user profile"
            },
            "x-defaultClientId": "api-web",
            "x-scalar-client-id": "api-web",
            "x-usePkce": "SHA-256",
            "x-scalar-credentials-location": "header"
          }
        }
      }
    },
    "schemas": {
      "id": {
        "type": "string",
        "format": "number",
        "description": "User ID from Authentik (need to change subject mode to User's ID instead of hashed)",
        "example": "100"
      },
      "Course": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "readOnly": true
          },
          "title": {
            "type": "string",
            "example": "Introduction to Programming"
          },
          "slug": {
            "type": "string",
            "example": "introduction-to-programming"
          },
          "instructorId": {
            "$ref": "#/components/schemas/id"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "approved",
              "published",
              "archived"
            ],
            "example": "draft"
          },
          "price": {
            "type": "integer",
            "format": "int64",
            "example": 1000000
          }
        },
        "required": [
          "id",
          "title",
          "slug",
          "instructorId",
          "status",
          "price"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code",
            "example": "EXAMPLE_CODE"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Example error"
          },
          "more_info": {
            "type": "string",
            "description": "URL with more information about the error",
            "example": "https://api.egolia.com/docs/errors/EXAMPLE_CODE"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "123e4567-e89b-12d3-a456-426614174000",
        "readOnly": true
      },
      "Lesson_properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "2926aa3f-29ad-449b-9556-c44d4fc676a0",
        "readOnly": true
      },
      "Lesson": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "2926aa3f-29ad-449b-9556-c44d4fc676a0",
            "readOnly": true
          },
          "courseId": {
            "$ref": "#/components/schemas/properties-id"
          },
          "title": {
            "type": "string",
            "example": "Introduction to Python"
          },
          "previousLessonId": {
            "$ref": "#/components/schemas/Lesson_properties-id",
            "example": "ed405041-986f-4750-92e6-617dd9337a78",
            "writeOnly": true
          }
        },
        "required": [
          "id",
          "title",
          "courseId"
        ]
      },
      "VideoLesson": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Lesson"
          },
          {
            "type": "object",
            "properties": {
              "videoUrl": {
                "type": "string",
                "format": "uri",
                "example": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
              },
              "duration": {
                "type": "integer",
                "format": "int64",
                "example": 300
              }
            },
            "required": [
              "videoUrl",
              "duration"
            ]
          }
        ]
      },
      "TestLesson": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Lesson"
          },
          {
            "type": "object",
            "required": [
              "type",
              "questions"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "singleChoice",
                  "multipleChoice"
                ],
                "example": "singleChoice"
              },
              "questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "x-go-type-name": "TestQuestion",
                  "required": [
                    "id",
                    "question",
                    "answers"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid",
                      "example": "6da7726c-18ba-4513-baa1-7e0eeef126d5",
                      "readOnly": true
                    },
                    "question": {
                      "type": "string",
                      "example": "What is the capital of France?"
                    },
                    "answers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "x-go-type-name": "TestAnswer",
                        "required": [
                          "id",
                          "content",
                          "isCorrect"
                        ],
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid",
                            "example": "bd0b3d9a-c5aa-497f-a904-a19cd1a5b3d6",
                            "readOnly": true
                          },
                          "content": {
                            "type": "string",
                            "example": "Paris"
                          },
                          "isCorrect": {
                            "type": "boolean",
                            "example": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "responses": {
      "BadRequestError": {
        "description": "Bad Request Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "BAD_REQUEST",
              "message": "The request could not be understood by the server due to malformed syntax",
              "more_info": "https://api.egolia.com/docs/errors/BAD_REQUEST"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Unauthorized Error response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "description": "The error response body returned when JWT validation or OPA authorization fails.",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "The category of the error encountered during the middleware lifecycle.",
                  "enum": [
                    "ExtractToken",
                    "VerifyToken",
                    "FetchJWKS",
                    "OPA"
                  ],
                  "example": "ExtractToken"
                },
                "details": {
                  "type": "string",
                  "description": "A descriptive message providing technical context for the failure.",
                  "x-examples": [
                    "token not found",
                    "Authorization header is empty",
                    "token is expired",
                    "failed to fetch JWKS",
                    "opa policy denied"
                  ],
                  "example": "token not found"
                },
                "custom_message": {
                  "type": "string",
                  "nullable": true,
                  "description": "An optional, developer-defined message, often populated by OPA policy violations.",
                  "example": "User does not have the required 'admin' role."
                }
              },
              "required": [
                "type",
                "details",
                "custom_message"
              ]
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "Forbidden Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "FORBIDDEN",
              "message": "You do not have permission to access this resource",
              "more_info": "https://api.egolia.com/docs/errors/FORBIDDEN"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal Server Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "INTERNAL_SERVER_ERROR",
              "message": "An internal server error occurred. Please try again later",
              "more_info": "https://api.egolia.com/docs/errors/INTERNAL_SERVER_ERROR"
            }
          }
        }
      }
    },
    "parameters": {
      "courseIdPath": {
        "name": "courseId",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/properties-id"
        }
      }
    }
  }
}