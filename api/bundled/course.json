  "components": {
    "securitySchemes": {
      "Oauth2": {
        "type": "oauth2",
        "description": "OAuth2 Security Scheme",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "http://authentik.egolia.localhost/application/o/authorize",
            "tokenUrl": "http://authentik.egolia.localhost/application/o/token",
            "scopes": {
              "openid": "Required for OIDC",
              "profile": "Access to user profile"
            },
            "x-defaultClientId": "api-web",
            "x-scalar-client-id": "api-web",
            "x-usePkce": "SHA-256",
            "x-scalar-credentials-location": "header"
          }
        }
      }
    },
    "schemas": {
      "id": {
        "type": "string",
        "format": "number",
        "description": "User ID from Authentik (need to change subject mode to User's ID instead of hashed)",
        "example": "100"
      },
      "Course": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "readOnly": true
          },
          "title": {
            "type": "string",
            "example": "Introduction to Programming"
          },
          "slug": {
            "type": "string",
            "example": "introduction-to-programming"
          },
          "instructorId": {
            "$ref": "#/components/schemas/id"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "approved",
              "published",
              "declined",
              "archived"
            ],
            "example": "draft"
          },
          "price": {
            "type": "integer",
            "format": "int64",
            "example": 1000000
          }
        },
        "required": [
          "id",
          "title",
          "slug",
          "instructorId",
          "status",
          "price"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code",
            "example": "EXAMPLE_CODE"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Example error"
          },
          "more_info": {
            "type": "string",
            "description": "URL with more information about the error",
            "example": "https://api.egolia.com/docs/errors/EXAMPLE_CODE"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "status": {
        "type": "string",
        "enum": [
          "draft",
          "approved",
          "published",
          "declined",
          "archived"
        ],
        "example": "draft"
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number",
            "minimum": 1,
            "example": 1
          },
          "limit": {
            "type": "integer",
            "description": "Number of items per page",
            "minimum": 1,
            "maximum": 100,
            "example": 20
          },
          "total": {
            "type": "integer",
            "description": "Total number of items",
            "minimum": 0,
            "example": 100
          },
          "totalPages": {
            "type": "integer",
            "description": "Total number of pages",
            "minimum": 0,
            "example": 5
          },
          "hasNext": {
            "type": "boolean",
            "description": "Whether there is a next page",
            "example": true
          },
          "hasPrev": {
            "type": "boolean",
            "description": "Whether there is a previous page",
            "example": false
          }
        },
        "required": [
          "page",
          "limit",
          "total",
          "totalPages",
          "hasNext",
          "hasPrev"
        ]
      },
      "properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "123e4567-e89b-12d3-a456-426614174000",
        "readOnly": true
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "0de4f8f2-3440-4e29-9b88-9cfbbf4476fc",
            "readOnly": true
          },
          "courseId": {
            "$ref": "#/components/schemas/properties-id"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "OOP Fundamentals"
          }
        },
        "required": [
          "id",
          "courseId",
          "title"
        ]
      },
      "Lesson_properties-id": {
        "type": "string",
        "format": "uuid",
        "example": "2926aa3f-29ad-449b-9556-c44d4fc676a0",
        "readOnly": true
      },
      "Lesson": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "2926aa3f-29ad-449b-9556-c44d4fc676a0",
            "readOnly": true
          },
          "courseId": {
            "$ref": "#/components/schemas/properties-id"
          },
          "title": {
            "type": "string",
            "example": "Introduction to Python"
          },
          "previousLessonId": {
            "$ref": "#/components/schemas/Lesson_properties-id",
            "example": "ed405041-986f-4750-92e6-617dd9337a78",
            "writeOnly": true
          }
        },
        "required": [
          "id",
          "title",
          "courseId"
        ]
      },
      "VideoLesson": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Lesson"
          },
          {
            "type": "object",
            "properties": {
              "videoUrl": {
                "type": "string",
                "format": "uri",
                "example": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
              },
              "duration": {
                "type": "integer",
                "format": "int64",
                "example": 300
              }
            },
            "required": [
              "videoUrl",
              "duration"
            ]
          }
        ]
      },
      "TestLesson": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Lesson"
          },
          {
            "type": "object",
            "required": [
              "type",
              "questions"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "singleChoice",
                  "multipleChoice"
                ],
                "example": "singleChoice"
              },
              "questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "x-go-type-name": "TestQuestion",
                  "required": [
                    "id",
                    "question",
                    "answers"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid",
                      "example": "6da7726c-18ba-4513-baa1-7e0eeef126d5",
                      "readOnly": true
                    },
                    "question": {
                      "type": "string",
                      "example": "What is the capital of France?"
                    },
                    "answers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "x-go-type-name": "TestAnswer",
                        "required": [
                          "id",
                          "content",
                          "isCorrect"
                        ],
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid",
                            "example": "bd0b3d9a-c5aa-497f-a904-a19cd1a5b3d6",
                            "readOnly": true
                          },
                          "content": {
                            "type": "string",
                            "example": "Paris"
                          },
                          "isCorrect": {
                            "type": "boolean",
                            "example": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "TestLessonType": {
        "type": "string",
        "enum": [
          "multipleChoice",
          "singleChoice"
        ],
        "example": "singleChoice"
      },
      "TestAnswer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "4c413364-151d-44e4-a357-c0c5cf7c5f4a",
            "readOnly": true
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "example": "Encapsulation hides implementation details behind a stable API."
          },
          "isCorrect": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "id",
          "content",
          "isCorrect"
        ]
      },
      "TestQuestion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "af2fb7f2-cf11-40d4-8628-b28f7d40f933",
            "readOnly": true
          },
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000,
            "example": "Which principle of OOP enables exposing only essential behavior?"
          },
          "answers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/TestAnswer"
            }
          }
        },
        "required": [
          "id",
          "question",
          "answers"
        ]
      }
