{
  "openapi": "3.0.4",
  "info": {
    "description": "Egolia API\n",
    "version": "0.0.0",
    "title": "Egolia API",
    "license": {
      "name": "MIT",
      "url": "https://github.com/egolia-uit/egolia/blob/main/LICENSE"
    },
    "contact": {
      "name": "Egolia Support",
      "email": "egolia@googlegroups.com"
    },
    "x-apiName": "billing"
  },
  "servers": [
    {
      "url": "http://api.egolia.localhost"
    }
  ],
  "tags": [
    {
      "name": "Billing",
      "description": "Billing related operations"
    }
  ],
  "externalDocs": {
    "url": "https://egolia-uit.github.io/egolia"
  },
  "paths": {
    "/billing/checkout": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Billing"
        ],
        "summary": "Checkout course",
        "operationId": "checkoutCourse",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Transaction"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Checkout transaction created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transaction"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/billing/admin/analytics/revenue": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Billing"
        ],
        "summary": "Get platform revenue analytics",
        "operationId": "getPlatformRevenueAnalytics",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "example": "2026-03-01"
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "example": "2026-03-31"
          }
        ],
        "responses": {
          "200": {
            "description": "Revenue analytics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RevenueAnalytics"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/billing/transactions": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Billing"
        ],
        "summary": "Get transactions",
        "operationId": "getTransactions",
        "parameters": [
          {
            "$ref": "#/components/parameters/pageQuery"
          },
          {
            "$ref": "#/components/parameters/limitQuery"
          },
          {
            "$ref": "#/components/parameters/orderQuery"
          },
          {
            "name": "courseId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "learnerId",
            "in": "query",
            "description": "If requested by non admin, then it will be that user",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Learner billing history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  },
                  "required": [
                    "data",
                    "pagination"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Oauth2": {
        "type": "oauth2",
        "description": "OAuth2 Security Scheme",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "http://authentik.egolia.localhost/application/o/authorize/",
            "tokenUrl": "http://authentik.egolia.localhost/application/o/token/",
            "scopes": {
              "openid": "Required for OIDC",
              "profile": "Access to user profile"
            },
            "x-defaultClientId": "api-web",
            "x-scalar-client-id": "api-web",
            "x-usePkce": "SHA-256",
            "x-scalar-credentials-location": "header"
          }
        }
      }
    },
    "schemas": {
      "id": {
        "type": "string",
        "format": "number",
        "description": "User ID from Authentik (need to change subject mode to User's ID instead of hashed)",
        "example": "100"
      },
      "username": {
        "type": "string",
        "description": "Username from Authentik",
        "example": "user"
      },
      "email": {
        "type": "string",
        "format": "email",
        "description": "Email from Authentik",
        "example": "user@egolia.com",
        "nullable": true
      },
      "title": {
        "type": "string",
        "example": "Introduction to Programming"
      },
      "TransactionStatus": {
        "type": "string",
        "description": "Current status of a billing transaction",
        "enum": [
          "pending",
          "completed",
          "failed"
        ],
        "example": "completed"
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "4c7c8f0a-4f6e-4da1-867d-38f1120f0e5d",
            "readOnly": true
          },
          "userId": {
            "$ref": "#/components/schemas/id",
            "readOnly": true
          },
          "username": {
            "$ref": "#/components/schemas/username",
            "readOnly": true
          },
          "userEmail": {
            "$ref": "#/components/schemas/email",
            "readOnly": true
          },
          "courseId": {
            "type": "string",
            "format": "uuid",
            "example": "0f4f19b1-1602-4c12-ac1a-9ad5baf1e4dc"
          },
          "courseTitle": {
            "$ref": "#/components/schemas/title",
            "readOnly": true
          },
          "amount": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "example": 499000,
            "readOnly": true
          },
          "status": {
            "$ref": "#/components/schemas/TransactionStatus",
            "readOnly": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-25T08:30:00Z",
            "readOnly": true
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time",
            "example": null,
            "nullable": true,
            "readOnly": true
          }
        },
        "required": [
          "id",
          "userId",
          "username",
          "userEmail",
          "courseId",
          "amount",
          "status",
          "createdAt",
          "issuedAt"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code",
            "example": "EXAMPLE_CODE"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Example error"
          },
          "more_info": {
            "type": "string",
            "description": "URL with more information about the error",
            "example": "https://api.egolia.com/docs/errors/EXAMPLE_CODE"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "RevenueAnalytics": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-22T10:30:00Z"
          },
          "to": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-22T10:30:00Z"
          },
          "totalRevenue": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "example": 152000000
          },
          "completedTransactions": {
            "type": "integer",
            "minimum": 0,
            "example": 421
          },
          "failedTransactions": {
            "type": "integer",
            "minimum": 0,
            "example": 9
          }
        },
        "required": [
          "from",
          "to",
          "totalRevenue",
          "completedTransactions",
          "failedTransactions"
        ]
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number",
            "minimum": 1,
            "example": 1
          },
          "limit": {
            "type": "integer",
            "description": "Number of items per page",
            "minimum": 1,
            "maximum": 100,
            "example": 20
          },
          "total": {
            "type": "integer",
            "description": "Total number of items",
            "minimum": 0,
            "example": 100
          },
          "totalPages": {
            "type": "integer",
            "description": "Total number of pages",
            "minimum": 0,
            "example": 5
          },
          "hasNext": {
            "type": "boolean",
            "description": "Whether there is a next page",
            "example": true
          },
          "hasPrev": {
            "type": "boolean",
            "description": "Whether there is a previous page",
            "example": false
          }
        },
        "required": [
          "page",
          "limit",
          "total",
          "totalPages",
          "hasNext",
          "hasPrev"
        ]
      }
    },
    "responses": {
      "BadRequestError": {
        "description": "Bad Request Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "BAD_REQUEST",
              "message": "The request could not be understood by the server due to malformed syntax",
              "more_info": "https://api.egolia.com/docs/errors/BAD_REQUEST"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Unauthorized Error response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "description": "The error response body returned when JWT validation or OPA authorization fails.",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "The category of the error encountered during the middleware lifecycle.",
                  "enum": [
                    "ExtractToken",
                    "VerifyToken",
                    "FetchJWKS",
                    "OPA"
                  ],
                  "example": "ExtractToken"
                },
                "details": {
                  "type": "string",
                  "description": "A descriptive message providing technical context for the failure.",
                  "x-examples": [
                    "token not found",
                    "Authorization header is empty",
                    "token is expired",
                    "failed to fetch JWKS",
                    "opa policy denied"
                  ],
                  "example": "token not found"
                },
                "custom_message": {
                  "type": "string",
                  "nullable": true,
                  "description": "An optional, developer-defined message, often populated by OPA policy violations.",
                  "example": "User does not have the required 'admin' role."
                }
              },
              "required": [
                "type",
                "details",
                "custom_message"
              ]
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "Forbidden Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "FORBIDDEN",
              "message": "You do not have permission to access this resource",
              "more_info": "https://api.egolia.com/docs/errors/FORBIDDEN"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal Server Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "INTERNAL_SERVER_ERROR",
              "message": "An internal server error occurred. Please try again later",
              "more_info": "https://api.egolia.com/docs/errors/INTERNAL_SERVER_ERROR"
            }
          }
        }
      }
    },
    "parameters": {
      "pageQuery": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "example": 1
      },
      "limitQuery": {
        "name": "limit",
        "in": "query",
        "description": "Number of items per page",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "example": 20
      },
      "orderQuery": {
        "name": "order",
        "in": "query",
        "description": "Sort order",
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "desc",
          "example": "desc"
        }
      }
    }
  }
}