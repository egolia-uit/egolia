{
  "openapi": "3.0.4",
  "info": {
    "description": "Egolia API\n",
    "version": "0.0.0",
    "title": "Egolia API",
    "license": {
      "name": "MIT",
      "url": "https://github.com/egolia-uit/egolia/blob/main/LICENSE"
    },
    "contact": {
      "name": "Egolia Support",
      "email": "egolia@googlegroups.com"
    },
    "x-apiName": "blog"
  },
  "servers": [
    {
      "url": "http://api.egolia.localhost"
    }
  ],
  "tags": [
    {
      "name": "Post",
      "description": "Blog post management"
    },
    {
      "name": "Comment",
      "description": "Post comments and replies"
    }
  ],
  "externalDocs": {
    "url": "https://egolia-uit.github.io/egolia"
  },
  "paths": {
    "/blog/posts": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Post"
        ],
        "summary": "Search posts",
        "operationId": "searchPosts",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Full-text keyword for post search",
            "schema": {
              "type": "string"
            },
            "example": "hoc tap hieu qua"
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Filter posts by tag",
            "schema": {
              "type": "string"
            },
            "example": "learning"
          },
          {
            "$ref": "#/components/parameters/pageQuery"
          },
          {
            "$ref": "#/components/parameters/limitQuery"
          },
          {
            "$ref": "#/components/parameters/orderQuery"
          }
        ],
        "responses": {
          "200": {
            "description": "Matched blog posts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostCollection"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Post"
        ],
        "summary": "Create post",
        "operationId": "createPost",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePostRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/blog/posts/{postId}": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Post"
        ],
        "summary": "Get post detail",
        "operationId": "getPostById",
        "parameters": [
          {
            "$ref": "#/components/parameters/postIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Blog post detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "put": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Post"
        ],
        "summary": "Update post",
        "operationId": "updatePost",
        "parameters": [
          {
            "$ref": "#/components/parameters/postIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Post updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Post"
        ],
        "summary": "Delete post",
        "operationId": "deletePost",
        "parameters": [
          {
            "$ref": "#/components/parameters/postIdPath"
          }
        ],
        "responses": {
          "204": {
            "description": "Post deleted successfully"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/blog/posts/{postId}/comments": {
      "get": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Comment"
        ],
        "summary": "Get post comments",
        "operationId": "getPostComments",
        "parameters": [
          {
            "$ref": "#/components/parameters/postIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Post comments with replies",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentCollection"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Comment"
        ],
        "summary": "Comment on post",
        "operationId": "commentOnPost",
        "parameters": [
          {
            "$ref": "#/components/parameters/postIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCommentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/blog/comments/{commentId}": {
      "put": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Comment"
        ],
        "summary": "Update comment",
        "operationId": "updateComment",
        "parameters": [
          {
            "$ref": "#/components/parameters/commentIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCommentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Comment"
        ],
        "summary": "Delete comment",
        "operationId": "deleteComment",
        "parameters": [
          {
            "$ref": "#/components/parameters/commentIdPath"
          }
        ],
        "responses": {
          "204": {
            "description": "Comment deleted successfully"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/blog/comments/{commentId}/replies": {
      "post": {
        "security": [
          {
            "Oauth2": []
          }
        ],
        "tags": [
          "Comment"
        ],
        "summary": "Reply comment",
        "operationId": "replyComment",
        "parameters": [
          {
            "$ref": "#/components/parameters/commentIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCommentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reply created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reply"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Oauth2": {
        "type": "oauth2",
        "description": "OAuth2 Security Scheme",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "http://authentik.egolia.localhost/application/o/authorize",
            "tokenUrl": "http://authentik.egolia.localhost/application/o/token",
            "scopes": {
              "openid": "Required for OIDC",
              "profile": "Access to user profile"
            },
            "x-defaultClientId": "api-web",
            "x-scalar-client-id": "api-web",
            "x-usePkce": "SHA-256",
            "x-scalar-credentials-location": "header"
          }
        }
      }
    },
    "parameters": {
      "pageQuery": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "example": 1
      },
      "limitQuery": {
        "name": "limit",
        "in": "query",
        "description": "Number of items per page",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "example": 20
      },
      "orderQuery": {
        "name": "order",
        "in": "query",
        "description": "Sort order",
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "desc",
          "example": "desc"
        }
      },
      "postIdPath": {
        "name": "postId",
        "in": "path",
        "required": true,
        "description": "Unique identifier of the blog post",
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "example": "74af02ce-4e69-4ca1-a721-c0e19c9937b8"
      },
      "commentIdPath": {
        "name": "commentId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid",
          "example": "8fd4f406-583d-4cd5-9c24-23c490a06711"
        }
      }
    },
    "schemas": {
      "id": {
        "type": "string",
        "format": "number",
        "description": "User ID from Authentik (need to change subject mode to User's ID instead of hashed)",
        "example": "100"
      },
      "Post": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "74af02ce-4e69-4ca1-a721-c0e19c9937b8",
            "readOnly": true
          },
          "authorId": {
            "$ref": "#/components/schemas/id"
          },
          "title": {
            "type": "string",
            "example": "Cach toi toi uu hanh trinh hoc tap"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Day la noi dung bai viet chia se kinh nghiem hoc tap tren Egolia."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "learning",
              "productivity"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-25T08:00:00Z",
            "readOnly": true
          },
          "commentCount": {
            "type": "integer",
            "minimum": 0,
            "example": 12,
            "readOnly": true
          }
        },
        "required": [
          "id",
          "authorId",
          "title",
          "content",
          "tags",
          "createdAt",
          "commentCount"
        ]
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number",
            "minimum": 1,
            "example": 1
          },
          "limit": {
            "type": "integer",
            "description": "Number of items per page",
            "minimum": 1,
            "maximum": 100,
            "example": 20
          },
          "total": {
            "type": "integer",
            "description": "Total number of items",
            "minimum": 0,
            "example": 100
          },
          "totalPages": {
            "type": "integer",
            "description": "Total number of pages",
            "minimum": 0,
            "example": 5
          },
          "hasNext": {
            "type": "boolean",
            "description": "Whether there is a next page",
            "example": true
          },
          "hasPrev": {
            "type": "boolean",
            "description": "Whether there is a previous page",
            "example": false
          }
        },
        "required": [
          "page",
          "limit",
          "total",
          "totalPages",
          "hasNext",
          "hasPrev"
        ]
      },
      "PostCollection": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Post"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        },
        "required": [
          "data",
          "pagination"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code",
            "example": "EXAMPLE_CODE"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Example error"
          },
          "more_info": {
            "type": "string",
            "description": "URL with more information about the error",
            "example": "https://api.egolia.com/docs/errors/EXAMPLE_CODE"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "CreatePostRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Cach toi toi uu hanh trinh hoc tap"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Day la noi dung bai viet chia se kinh nghiem hoc tap tren Egolia."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "learning",
              "productivity"
            ]
          }
        },
        "required": [
          "title",
          "content",
          "tags"
        ]
      },
      "UpdatePostRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Cach toi toi uu hanh trinh hoc tap"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Day la noi dung bai viet chia se kinh nghiem hoc tap tren Egolia."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "learning",
              "productivity"
            ]
          }
        },
        "required": [
          "title",
          "content",
          "tags"
        ]
      },
      "Reply": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "d1a8eaf7-2b37-4d6d-970f-d61c8fe95654",
            "readOnly": true
          },
          "authorId": {
            "$ref": "#/components/schemas/id"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Minh dong y voi y kien nay."
          },
          "parentCommentId": {
            "type": "string",
            "format": "uuid",
            "example": "834897ce-45e7-43a5-92b2-4ec1f0dc3cd1",
            "readOnly": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-25T09:15:00Z",
            "readOnly": true
          }
        },
        "required": [
          "id",
          "authorId",
          "content",
          "parentCommentId",
          "createdAt"
        ]
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "834897ce-45e7-43a5-92b2-4ec1f0dc3cd1",
            "readOnly": true
          },
          "authorId": {
            "$ref": "#/components/schemas/id"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Bai viet nay rat huu ich."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-25T09:00:00Z",
            "readOnly": true
          },
          "replies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reply"
            }
          }
        },
        "required": [
          "id",
          "authorId",
          "content",
          "createdAt",
          "replies"
        ]
      },
      "CommentCollection": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          }
        },
        "required": [
          "data"
        ]
      },
      "CreateCommentRequest": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Cam on ban da chia se."
          }
        },
        "required": [
          "content"
        ]
      },
      "CommentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "834897ce-45e7-43a5-92b2-4ec1f0dc3cd1",
            "readOnly": true
          },
          "authorId": {
            "$ref": "#/components/schemas/id"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Bai viet nay rat huu ich."
          },
          "parentCommentId": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "example": null,
            "readOnly": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-25T09:00:00Z",
            "readOnly": true
          }
        },
        "required": [
          "id",
          "authorId",
          "content",
          "parentCommentId",
          "createdAt"
        ]
      },
      "UpdateCommentRequest": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "minLength": 1,
            "example": "Minh da cap nhat lai noi dung binh luan."
          }
        },
        "required": [
          "content"
        ]
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Unauthorized Error response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "description": "The error response body returned when JWT validation or OPA authorization fails.",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "The category of the error encountered during the middleware lifecycle.",
                  "enum": [
                    "ExtractToken",
                    "VerifyToken",
                    "FetchJWKS",
                    "OPA"
                  ],
                  "example": "ExtractToken"
                },
                "details": {
                  "type": "string",
                  "description": "A descriptive message providing technical context for the failure.",
                  "x-examples": [
                    "token not found",
                    "Authorization header is empty",
                    "token is expired",
                    "failed to fetch JWKS",
                    "opa policy denied"
                  ],
                  "example": "token not found"
                },
                "custom_message": {
                  "type": "string",
                  "nullable": true,
                  "description": "An optional, developer-defined message, often populated by OPA policy violations.",
                  "example": "User does not have the required 'admin' role."
                }
              },
              "required": [
                "type",
                "details",
                "custom_message"
              ]
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal Server Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "code": "INTERNAL_SERVER_ERROR",
              "message": "An internal server error occurred. Please try again later",
              "more_info": "https://api.egolia.com/docs/errors/INTERNAL_SERVER_ERROR"
            }
          }
        }
      },
      "BadRequestError": {
        "description": "Bad Request Error response",
