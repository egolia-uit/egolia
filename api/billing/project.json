{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "api/billing",
  "projectType": "application",
  "tags": ["scope:api", "type:openapi"],
  "targets": {
    "bundle:json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "redocly bundle billing --config ../redocly.yaml",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/../bundled/billing.json"],
      "inputs": ["openapiFilesWithCommon"]
    },
    "build": {
      "dependsOn": ["bundle:json"]
    },
    "watch-bundle:json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx watch --projects=api/billing -- pnpm nx run api/billing:bundle:json",
        "forwardAllArgs": false,
        "cwd": "{workspaceRoot}"
      },
      "continuous": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scalar document serve -w ../bundled/billing.json --port 9082",
        "forwardAllArgs": false,
        "cwd": "{projectRoot}"
      },
      "continuous": true,
      "dependsOn": ["watch-bundle:json", "bundle:json"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scalar document serve ../bundled/billing.json --port 9082",
        "cwd": "{projectRoot}"
      },
      "continuous": true,
      "dependsOn": ["bundle:json"]
    },
    "mock": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scalar document mock ../bundled/billing.json --port 8082",
        "cwd": "{projectRoot}"
      },
      "continuous": true,
      "dependsOn": ["bundle:json"]
    },
    "mock:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scalar document mock -w ../bundled/billing.json --port 8082",
        "cwd": "{projectRoot}"
      },
      "continuous": true,
      "dependsOn": ["watch-bundle:json", "bundle:json"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "redocly lint billing --config ../redocly.yaml",
        "cwd": "{projectRoot}"
      },
      "inputs": ["openapiFilesWithCommon"]
    },
    "gen:gomodel": {
      "inputs": ["{projectRoot}/oapi-codegen-model.yaml", "openapiFiles"],
      "outputs": ["{workspaceRoot}/pkg/api/billing/billingmodel.gen.go"],
      "executor": "nx:run-commands",
      "options": {
        "command": "oapi-codegen --config ./oapi-codegen-model.yaml ../bundled/billing.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["bundle:json"]
    },
    "gen:goserver": {
      "inputs": ["{projectRoot}/oapi-codegen-server.yaml", "openapiFiles"],
      "outputs": ["{workspaceRoot}/pkg/api/billing/billingserver.gen.go"],
      "executor": "nx:run-commands",
      "options": {
        "command": "oapi-codegen --config ./oapi-codegen-server.yaml ../bundled/billing.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["bundle:json"]
    },
    "gen:go": {
      "dependsOn": ["gen:gomodel", "gen:goserver"]
    },
    "gen": {
      "dependsOn": ["gen:go"]
    }
  }
}
