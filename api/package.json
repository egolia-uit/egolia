{
  "name": "@egolia-uit/api",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./openapi": "./bundled/openapi.json",
    "./course": "./bundled/course.json",
    "./billing": "./bundled/billing.json",
    "./blog": "./bundled/blog.json"
  },
  "scripts": {
    "openapi-ts": "openapi-ts",
    "redocly": "redocly",
    "redocly:join": "redocly join ./openapi.yaml ./bundled/course.json ./bundled/billing.json ./bundled/blog.json --prefix-components-with-info-prop x-apiName -o ./bundled/openapi.json",
    "scalar": "scalar"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "catalog:",
    "@redocly/cli": "catalog:",
    "@scalar/cli": "catalog:"
  }
}
