{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>egolia-uit/renovate-config",
    ":automergeBranch",
    ":automergePatch"
  ],
  "packageRules": [
    {
      "groupName": "Nx Monorepo Toolkit",
      "matchPackageNames": ["nx", "/^@nx//", "/^nx$/", "/^npm:nx$/"],
      "automerge": false,
      "description": "Group all Nx packages to prevent version mismatch and allow manual migration. Note that renovate still create PRs for minor/major updates, but they will not be automerged."
    },
    {
      "groupName": "Codegen",
      "matchPackageNames": [
        "@hey-api/openapi-ts",
        "github.com/oapi-codegen/runtime",
        "go:github.com/oapi-codegen/oapi-codegen/v2/cmd/oapi-codegen"
      ],
      "automerge": true,
      "matchUpdateTypes": ["patch", "minor"]
    }
  ],
  "docker-compose": {
    "managerFilePatterns": ["/^deploy\\/compose\\/.+\\/.+\\.ya?ml$/"]
  },
  "schedule": ["* 1-18 * * 3,0"]
}
