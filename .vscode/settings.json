{
  "editor.formatOnSave": true,
  "[go]": {
    "editor.tabSize": 8,
    "editor.insertSpaces": false
  },
  "[typescript][html][css][scss][json][yaml][markdown]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "github.copilot.chat.getSearchViewResultsSkill.enabled": true,
  "redoclyOpenAPI.configPath": "./api/redocly.yaml",
  "go.goroot": "${userHome}/.local/share/mise/installs/go/1.26.2",
  "debug.javascript.defaultRuntimeExecutable": {
    "pwa-node": "${userHome}/.local/share/mise/shims/node"
  },
  "go.alternateTools": {
    "go": "${userHome}/.local/share/mise/shims/go",
  }
}