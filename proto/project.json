{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "proto",
  "projectType": "library",
  "tags": ["scope:api", "type:proto"],
  "targets": {
    "gen": {
      "inputs": ["protoFiles"],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/pkg/pb",
        "{workspaceRoot}/packages/pb"
      ],
      "options": {
        "command": "buf generate"
      }
    },
    "lint": {
      "inputs": ["protoFiles"],
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint"
      }
    }
  }
}
